# ============================================================
# 主升浪加速行情自动扫描与决策 Bot 系统 - 配置文件
# ============================================================
# 复制此文件为 .env 并填入你的 Token

# ========== 通知推送配置 ==========
# Server酱 (微信通知) - https://sct.ftqq.com/
SC_KEY=your_serverchan_key_here

# PushPlus (微信通知) - https://www.pushplus.plus/
PUSHPLUS_TOKEN=your_pushplus_token_here

# Telegram Bot - https://t.me/BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# 钉钉机器人 - https://open.dingtalk.com/document/robots/custom-robot-access
# 获取方式: 钉钉群 -> 群设置 -> 智能群助手 -> 添加机器人 -> 自定义
DINGTALK_WEBHOOK=your_dingtalk_webhook_url
# 钉钉加签密钥 (安全设置选择"加签"时填写, 留空则不签名)
DINGTALK_SECRET=

# 企业微信群机器人 - https://developer.work.weixin.qq.com/document/path/91770
# 获取方式: 企微群 -> 群设置 -> 添加群机器人 -> Webhook地址
WECOM_WEBHOOK=your_wecom_webhook_url

# Discord Webhook - https://discord.com/developers/docs/resources/webhook
# 获取方式: Discord服务器 -> 频道设置 -> 整合 -> Webhook -> 新建Webhook
DISCORD_WEBHOOK=your_discord_webhook_url

# Webhook 重试配置 (防网络波动漏报)
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_DELAY=1.0

# ========== Tushare Token (可选, AkShare 无需) ==========
TUSHARE_TOKEN=your_tushare_token_here

# ========== 扫描策略参数 ==========
# 市场选择: A股(a_share) / 美股(us_stock) / 全部(all)
MARKET=a_share

# 扫描范围: all(全市场) / custom(自定义股票池)
SCAN_SCOPE=all

# 自定义股票池 (逗号分隔, 仅 SCAN_SCOPE=custom 时生效)
CUSTOM_STOCKS=000001,000002,600519,300750,002594

# 四维硬核动量模型参数 (v2.0)
# 1. 均线完美多头排列: Price > MA5 > MA10 > MA20 > MA60 且 MA20 > MA60 > MA120
# 2. 动量爆发与放量破局: 创20/60日新高 + 成交量 > 5日/20日均量 * 2.0
# 3. VCP波动率收敛后突破: 10日振幅收敛 + 大阳线突破 + 布林带开口剧烈放大
# 4. 大盘环境过滤器: 指数MA20过滤器, 跌破触发空仓熔断

# 放量倍数阈值 (量比 > 此值视为放量, 默认 2.0 倍)
VOLUME_SURGE_RATIO=2.0

# VCP 振幅收敛比阈值 (前半段均振幅 / 后半段均振幅 > 此值视为收敛)
VCP_CONTRACTION_THRESHOLD=1.3

# 布林带开口放大倍数 (当日带宽 > 20日均值 * 此值视为剧烈扩张)
BOLLINGER_EXPLODE_RATIO=1.5

# 突破大阳线最低实体涨幅 %
CANDLE_BODY_MIN_PCT=3.0

# 涨幅过滤: 只扫描当日涨幅 > 此值的股票 (0=不过滤扫描全市场, 5=只扫涨幅>5%)
# 涨幅过滤可大幅减少扫描数量 (5000+ → 几十~两百家), 总耗时从小时级降至分钟级
MIN_CHANGE_PCT=5.0

# 涨停股扫描模式: 1=只扫描涨停股 (~20-100只, 极速), 0=使用涨幅过滤
# 涨停股模式优先级高于 MIN_CHANGE_PCT, 启用后只扫描当日涨停的股票
# 数据源: 东财涨停板API(push2ex) → Baostock(50线程兜底)
SCAN_ZT_ONLY=1

# RSI 健康区间 (仅用于评分加减分, 不作为硬过滤)
RSI_LOWER=50
RSI_UPPER=85

# ========== 运行模式 ==========
# dry_run: 仅扫描不推送通知
# notify: 扫描并推送通知
RUN_MODE=notify
